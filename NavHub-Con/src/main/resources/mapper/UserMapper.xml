<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.navhub.mapper.UserMapper">
    
    <resultMap id="UserResultMap" type="com.navhub.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="email" column="email"/>
        <result property="isAdmin" column="is_admin"/>
        <result property="avatar" column="avatar"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>
    
    <select id="findByUsername" resultMap="UserResultMap">
        SELECT * FROM user WHERE username = #{username}
    </select>
    
    <select id="findById" resultMap="UserResultMap">
        SELECT * FROM user WHERE id = #{id}
    </select>
    
    <insert id="insert">
        INSERT INTO user (id, username, password, email, is_admin, avatar, created_at, updated_at)
        VALUES (#{id}, #{username}, #{password}, #{email}, #{isAdmin}, #{avatar}, #{createdAt}, #{updatedAt})
    </insert>
    
    <update id="update">
        UPDATE user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="email != null">email = #{email},</if>
            <if test="isAdmin != null">is_admin = #{isAdmin},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>
    
    <delete id="deleteById">
        DELETE FROM user WHERE id = #{id}
    </delete>
</mapper>
