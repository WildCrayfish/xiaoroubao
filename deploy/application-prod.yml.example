server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://mysql:3306/navhub?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8
    username: navhub
    password: your_db_password
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false

